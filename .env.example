# Copier vers .env à la racine : cp .env.example .env (ou copie manuelle sous Windows)
# Le dépôt ne versionne pas .env (secrets). Voir CONFIGURATION.md pour le détail.

# PostgreSQL — profil dashboard, progression (Drizzle)
# Local avec Docker : docker compose up -d puis :
# DATABASE_URL=postgresql://wingadex:wingadex@localhost:5432/wingadex
# Puis : npm run db:push
DATABASE_URL=

# Secret pour les sessions (obligatoire en prod). Générer : openssl rand -base64 32
NUXT_AUTH_SECRET=

# URL complète du endpoint Auth.js (optionnel). Par défaut : NUXT_PUBLIC_SITE_URL + /api/auth
# Ex. https://wingadex.example.com/api/auth
NUXT_AUTH_ORIGIN=

# OAuth Google — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Discord — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# URL publique du site (Nuxt runtimeConfig.public.siteUrl)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
